  "usage_quickstart": {
    "step_1": "前端读取 index.json 获取所有词库元数据",
    "step_2": "按 form_default_selection 渲染表单初始值",
    "step_3": "用户选择/修改 → 收集 form_state 对象（各字段 = id）",
    "step_4": "后端按 form_state 中每个 id 去对应 JSON 文件取出 keywords_en（或 name_en）",
    "step_5": "套用 prompt_templates.json 中选定的模板字符串，替换 {{...}} 占位符",
    "step_6": "调 LLM (DeepSeek / Qwen) 做最终润色：合并去重、翻译 freetext、补齐缺失、限制词数",
    "step_7": "输出三个产物：英文 Prompt（主）+ 中文版（参考）+ 负向词（独立字段）+ MJ suffix（独立）"
  }

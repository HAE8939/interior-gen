# ─── LLM（翻译 / 润色）───────────────────────────────────────────────────────
# 用于将中文自由输入翻译成英文，以及对 Prompt 进行润色
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ─── 生图 / 改图接口 ──────────────────────────────────────────────────────────
# 支持 GPT-image-2、Nano banana 等 OpenAI 兼容接口
IMAGE_GEN_API_KEY=
IMAGE_GEN_BASE_URL=https://api.openai.com
IMAGE_GEN_MODEL=gpt-image-2
